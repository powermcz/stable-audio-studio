{
  "name": "stable-audio-studio",
  "version": "0.1.5",
  "description": "Desktop audio studio powered by Stable Audio Open 1.0",
  "main": "out/main/index.js",
  "author": "powermcz",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --config electron-builder.yml",
    "package:win": "electron-builder --win --config electron-builder.yml",
    "package:mac": "electron-builder --mac --config electron-builder.yml",
    "package:linux": "electron-builder --linux --config electron-builder.yml",
    "lint": "eslint src/ electron/",
    "typecheck": "tsc --noEmit",
    "test:backend": "cd python && venv/Scripts/python -m pytest tests/test_e2e_generation.py -v -s",
    "test:smoke": "cd python && venv/Scripts/python tests/smoke_test.py",
    "python:setup": "cd python && python -m venv venv && venv/Scripts/pip install -r requirements.txt",
    "python:dev": "cd python && venv/Scripts/python -m uvicorn server.main:app --reload --port 8765"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "wavesurfer.js": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
